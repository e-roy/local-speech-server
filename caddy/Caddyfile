{
    admin off
    auto_https off
    log {
        output stdout
        format console
        level INFO
    }
}

:8080 {
    encode gzip

    header -Server

    # CORS allowlist: matches when the request's Origin header is one of the
    # pipe-separated values in $ALLOWED_ORIGINS. The pipes double as regex
    # alternation, so '.' is technically a wildcard — fine for typical
    # subdomain allowlists; escape as '\.' in .env if you need strictness.
    @allowedOrigin header_regexp Origin "^({$ALLOWED_ORIGINS})$"

    @preflight method OPTIONS
    handle @preflight {
        header @allowedOrigin Access-Control-Allow-Origin "{http.request.header.Origin}"
        header @allowedOrigin Access-Control-Allow-Methods "GET, POST, OPTIONS"
        header @allowedOrigin Access-Control-Allow-Headers "Authorization, Content-Type"
        header @allowedOrigin Access-Control-Max-Age "86400"
        header Vary "Origin"
        respond 204
    }

    # Static voice-browser page (unauthenticated — the page itself contains
    # no secrets; the API calls it makes still require a bearer token).
    @static path /voices /voices.html
    handle @static {
        root * /srv
        rewrite /voices /voices.html
        file_server
    }

    # Reject placeholder credentials explicitly so a default-config boot
    # cannot serve real traffic.
    @placeholder header_regexp Authorization "^Bearer CHANGEME_"
    handle @placeholder {
        respond "Refusing placeholder API key from .env.example. Run ./scripts/init-env.sh." 401 {
            close
        }
    }

    @authed header_regexp Authorization "^Bearer ({$API_KEYS})$"
    handle @authed {
        header @allowedOrigin Access-Control-Allow-Origin "{http.request.header.Origin}"
        header Vary "Origin"

        reverse_proxy kokoro:8880 {
            header_down -Access-Control-Allow-Origin
            header_down -Access-Control-Allow-Methods
            header_down -Access-Control-Allow-Headers
            header_down -Access-Control-Max-Age
            header_down -Access-Control-Allow-Credentials
            header_down -Vary
            flush_interval -1
        }
    }

    handle {
        respond "Unauthorized" 401 {
            close
        }
    }
}
