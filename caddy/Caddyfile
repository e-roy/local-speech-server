{
    admin off
    auto_https off
    log {
        output stdout
        format console
        level INFO
    }
}

:8080 {
    encode gzip

    header -Server

    # CORS allowlist: matches when the request's Origin header is one of the
    # pipe-separated values in $ALLOWED_ORIGINS. The pipes double as regex
    # alternation, so '.' is technically a wildcard — fine for typical
    # subdomain allowlists; escape as '\.' in .env if you need strictness.
    @allowedOrigin header_regexp Origin "^({$ALLOWED_ORIGINS})$"

    @preflight method OPTIONS
    handle @preflight {
        header @allowedOrigin Access-Control-Allow-Origin "{http.request.header.Origin}"
        header @allowedOrigin Access-Control-Allow-Methods "GET, POST, OPTIONS"
        header @allowedOrigin Access-Control-Allow-Headers "Authorization, Content-Type"
        header @allowedOrigin Access-Control-Max-Age "86400"
        header Vary "Origin"
        respond 204
    }

    # Static voice-browser page (unauthenticated — the page itself contains
    # no secrets; the API calls it makes still require a bearer token).
    @static path /voices /voices.html
    handle @static {
        root * /srv
        rewrite /voices /voices.html
        file_server
    }

    # Reject placeholder credentials explicitly so a default-config boot
    # cannot serve real traffic.
    @placeholder header_regexp Authorization "^Bearer CHANGEME_"
    handle @placeholder {
        respond "Refusing placeholder API key from .env.example. Run ./scripts/init-env.sh." 401 {
            close
        }
    }

    @authed header_regexp Authorization "^Bearer ({$API_KEYS})$"
    handle @authed {
        header @allowedOrigin Access-Control-Allow-Origin "{http.request.header.Origin}"
        header Vary "Origin"

        # TTS + voice listing — Kokoro-FastAPI. (Speaches exposes its own
        # /v1/audio/voices for its TTS side; routing the path here shadows
        # it deliberately — Kokoro is the TTS engine.)
        @kokoro path /v1/audio/speech* /v1/audio/voices*
        handle @kokoro {
            reverse_proxy kokoro:8880 {
                header_down -Access-Control-Allow-Origin
                header_down -Access-Control-Allow-Methods
                header_down -Access-Control-Allow-Headers
                header_down -Access-Control-Max-Age
                header_down -Access-Control-Allow-Credentials
                header_down -Vary
                flush_interval -1
            }
        }

        # STT (transcriptions) — mlx-audio on the HOST (native; the M4's
        # GPU via MLX). request_body is a standalone directive (NOT valid
        # inside reverse_proxy); the cap matches Cloudflare's own 100 MB
        # request-body limit on Free/Pro plans. Beyond it Caddy answers 413.
        # Rollback to the CPU engine: change the upstream back to
        # speaches:8000 and restart caddy.
        @stt path /v1/audio/transcriptions*
        handle @stt {
            request_body {
                max_size 100MB
            }
            reverse_proxy host.docker.internal:8001 {
                transport http {
                    # Fail fast when the engine is off (see handle_errors).
                    dial_timeout 2s
                }
                # Same defenses as the Ollama route: present the upstream's
                # own name and drop Origin — Caddy owns CORS.
                header_up Host {upstream_hostport}
                header_up -Origin
                header_down -Access-Control-Allow-Origin
                header_down -Access-Control-Allow-Methods
                header_down -Access-Control-Allow-Headers
                header_down -Access-Control-Max-Age
                header_down -Access-Control-Allow-Credentials
                header_down -Vary
                # Unbuffered so streamed transcripts flow as produced.
                flush_interval -1
            }
        }

        # Translations (audio → English) — stays on Speaches; mlx-audio
        # does not expose the endpoint.
        @translations path /v1/audio/translations*
        handle @translations {
            request_body {
                max_size 100MB
            }
            reverse_proxy speaches:8000 {
                header_down -Access-Control-Allow-Origin
                header_down -Access-Control-Allow-Methods
                header_down -Access-Control-Allow-Headers
                header_down -Access-Control-Max-Age
                header_down -Access-Control-Allow-Credentials
                header_down -Vary
                flush_interval -1
            }
        }

        # Model discovery — read-only. Lets OpenAI SDKs and agents list the
        # installed STT models instead of guessing IDs. GET only: model
        # install (POST) and delete stay unexposed, operator-only.
        # Note: lists Speaches' models — TTS is always model "kokoro" and
        # its voices come from /v1/audio/voices.
        @models {
            method GET
            path /v1/models /v1/models/*
        }
        handle @models {
            reverse_proxy speaches:8000 {
                header_down -Access-Control-Allow-Origin
                header_down -Access-Control-Allow-Methods
                header_down -Access-Control-Allow-Headers
                header_down -Access-Control-Max-Age
                header_down -Access-Control-Allow-Credentials
                header_down -Vary
            }
        }

        # Realtime voice sessions (WebSocket) — Speaches orchestrates
        # STT → LLM (host-side Ollama) → TTS server-side. Server-side
        # clients authenticate with the normal Authorization header;
        # browser WebSocket clients cannot set one and use the scoped
        # query-param matcher further below instead.
        @realtime path /v1/realtime
        handle @realtime {
            reverse_proxy speaches:8000 {
                header_down -Access-Control-Allow-Origin
                header_down -Access-Control-Allow-Methods
                header_down -Access-Control-Allow-Headers
                header_down -Access-Control-Max-Age
                header_down -Access-Control-Allow-Credentials
                header_down -Vary
            }
        }

        # LLM — Ollama on the HOST (native; MLX-accelerated on Apple
        # Silicon), not a container. /v1/llm/* is the LLM's own OpenAI
        # surface: point an OpenAI client at https://<host>/v1/llm and
        # chat.completions / models.list() work unmodified. handle_path
        # strips /v1/llm and the rewrite restores /v1, so only Ollama's
        # OpenAI-compatible routes are reachable — its native /api/*
        # (pull, delete, etc.) is not.
        handle_path /v1/llm/* {
            rewrite * /v1{uri}
            reverse_proxy host.docker.internal:11434 {
                transport http {
                    # Fail fast when Ollama is off (see handle_errors below).
                    dial_timeout 2s
                }
                # Ollama's DNS-rebinding protection 403s requests whose Host
                # isn't localhost-like or allowlisted; the public hostname
                # fails that check. Present the upstream's own name
                # (*.internal is on Ollama's allowlist) and drop Origin —
                # Caddy owns CORS and Ollama would 403 foreign origins.
                header_up Host {upstream_hostport}
                header_up -Origin
                header_down -Access-Control-Allow-Origin
                header_down -Access-Control-Allow-Methods
                header_down -Access-Control-Allow-Headers
                header_down -Access-Control-Max-Age
                header_down -Access-Control-Allow-Credentials
                header_down -Vary
                # Unbuffered so chat token streaming (SSE) flows live.
                flush_interval -1
            }
        }

        # Anything else, even with a valid key, is not part of the service
        # surface (backends expose more routes than we publish).
        handle {
            respond "Not found" 404 {
                close
            }
        }
    }

    # Browser WebSocket clients cannot send an Authorization header, so
    # /v1/realtime (and only it) also accepts the key as ?api_key=<key>.
    # Placeholder rejection is checked first, mirroring the header path.
    # Note: URLs appear in edge/proxy logs — clients that can set headers
    # should keep using header auth.
    @placeholderQueryKey expression `path('/v1/realtime') && {http.request.uri.query.api_key}.startsWith('CHANGEME_')`
    handle @placeholderQueryKey {
        respond "Refusing placeholder API key from .env.example. Run ./scripts/init-env.sh." 401 {
            close
        }
    }

    @realtimeQueryAuth expression `path('/v1/realtime') && {http.request.uri.query.api_key}.matches('^({$API_KEYS})$')`
    handle @realtimeQueryAuth {
        reverse_proxy speaches:8000 {
            header_down -Access-Control-Allow-Origin
            header_down -Access-Control-Allow-Methods
            header_down -Access-Control-Allow-Headers
            header_down -Access-Control-Max-Age
            header_down -Access-Control-Allow-Credentials
            header_down -Vary
        }
    }

    handle {
        respond "Unauthorized" 401 {
            close
        }
    }

    # When a backend is unreachable (connection refused / dial timeout),
    # shape the error as OpenAI-style JSON so SDK consumers get a catchable,
    # explanatory APIError instead of an empty 502. In practice the only
    # routinely-absent backend is the host-side Ollama (the Docker engines
    # restart with the stack).
    handle_errors 502 503 504 {
        header Content-Type application/json
        respond `{"error":{"message":"Upstream engine unavailable. A host-side engine may be down: Ollama serves /v1/llm, mlx-audio serves /v1/audio/transcriptions. See docs/operations.md.","type":"api_error","code":"upstream_unavailable"}}`
    }
}
