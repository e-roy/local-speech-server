# Pipe-separated list of valid bearer-token API keys.
# DO NOT use the CHANGEME_ values below — Caddy will refuse them.
# Generate real keys with:
#   ./scripts/init-env.sh
# Or generate them by hand:
#   ./scripts/generate-key.sh
API_KEYS=CHANGEME_KEY_1|CHANGEME_KEY_2

# Pipe-separated CORS origin allowlist. Browsers loaded from any of these
# may call the service.
#
#   Single origin: ALLOWED_ORIGINS=https://your-app.example.com
#   Multiple:      ALLOWED_ORIGINS=https://app.example.com|https://staging.example.com|http://localhost:5173
#
# Values are joined into a regex alternation, so '.' technically matches
# any character. Fine for typical subdomain allowlists; escape as '\.' if
# you need strictness.
ALLOWED_ORIGINS=https://your-app.example.com

# Cloudflare Tunnel token (created in the Cloudflare Zero Trust dashboard).
# Looks like: eyJhIjoiYWxwaGFudW0...
CLOUDFLARE_TUNNEL_TOKEN=CHANGEME_TUNNEL_TOKEN

# Optional: the public URL of this service, e.g. https://speech.example.com
# (no /v1, no trailing slash). Used only by scripts/verify-stack.sh to know
# where to send its test requests — no container reads it. If left empty,
# the script falls back to the first entry in ALLOWED_ORIGINS, which is
# usually a consumer app's origin rather than this service.
SPEECH_BASE=

# The STT model consumers pass to /v1/audio/transcriptions, served by the
# host-side mlx-audio engine (docs/stt.md). Read by verify-stack.sh only —
# no container uses it. Adjust if you install a different model.
STT_MODEL=mlx-community/whisper-large-v3-turbo-asr-fp16
